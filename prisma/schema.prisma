model decommission_acts {
  id           String                @id @default(cuid())
  folio        String                @unique
  requestId    String                @unique @map("request_id")
  approvedById String                @map("approved_by_id")
  approvedAt   DateTime              @default(now()) @map("approved_at")
  pdfPath      String?               @map("pdf_path")
  createdAt    DateTime              @default(now()) @map("created_at")
  approvedBy   users                 @relation("DecommissionApprover", fields: [approvedById], references: [id])
  request      decommission_requests @relation(fields: [requestId], references: [id])

  @@index([folio])
  @@map("decommission_acts")
}

model folio_counters {
  id         String @id @default(uuid())
  year       Int
  type       String
  lastNumber Int    @default(0) @map("last_number")

  @@unique([year, type])
  @@map("folio_counters")
}

model families {
  id                          String                          @id @default(uuid())
  code                        String                          @unique @db.VarChar(50)
  name                        String                          @db.VarChar(100)
  description                 String?
  icon                        String?                         @db.VarChar(50)
  color                       String?                         @default("#6B7280") @db.VarChar(20)
  isActive                    Boolean                         @default(true) @map("is_active")
  order                       Int                             @default(0)
  createdAt                   DateTime                        @default(now()) @map("created_at")
  updatedAt                   DateTime                        @updatedAt @map("updated_at")
  adminFamilyAssignments      admin_family_assignments[]
  consumableTypes             consumable_types[]
  departments                 departments[]
  equipmentTypes              equipment_types[]
  formConfig                  inventory_family_config?
  managerFamilies             inventory_manager_families[]
  knowledge_articles          knowledge_articles[]
  licenseTypes                license_types[]
  sla_policies                sla_policies[]
  supplierTypes               supplier_types[]
  suppliers                   suppliers[]
  technicianFamilyAssignments technician_family_assignments[]
  warehouses                  warehouses[]
  ticketCodeCounters          ticket_code_counters[]
  ticketFamilyConfig          ticket_family_config?
  tickets                     tickets[]
  contracts                   contracts[]

  @@index([isActive, order])
  @@map("families")
}

model warehouses {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(100)
  location    String?       @db.VarChar(200)
  description String?
  managerId   String?       @map("manager_id")
  familyId    String?       @map("family_id")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  consumables consumables[]
  equipment   equipment[]
  family      families?     @relation(fields: [familyId], references: [id])
  manager     users?        @relation("WarehouseManager", fields: [managerId], references: [id])

  @@index([isActive])
  @@index([familyId, isActive])
  @@map("warehouses")
}

model inventory_manager_families {
  id        String   @id @default(uuid())
  managerId String   @map("manager_id")
  familyId  String   @map("family_id")
  createdAt DateTime @default(now()) @map("created_at")
  family    families @relation(fields: [familyId], references: [id], onDelete: Cascade)
  manager   users    @relation("InventoryManagerFamilies", fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([managerId, familyId])
  @@index([managerId])
  @@index([familyId])
  @@map("inventory_manager_families")
}

model license_attachments {
  id           String            @id @default(uuid())
  licenseId    String            @map("license_id")
  filename     String
  originalName String            @map("original_name")
  mimeType     String            @map("mime_type")
  size         Int
  path         String
  uploadedBy   String            @map("uploaded_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  license      software_licenses @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  uploader     users             @relation(fields: [uploadedBy], references: [id])

  @@index([licenseId])
  @@map("license_attachments")
}

model inventory_family_config {
  id                        String              @id @default(uuid())
  familyId                  String              @unique @map("family_id")
  allowedSubtypes           AssetSubtype[]      @map("allowed_subtypes")
  visibleSections           FormSection[]       @map("visible_sections")
  requiredSections          FormSection[]       @map("required_sections")
  requireFinancialForNew    Boolean             @default(true) @map("require_financial_for_new")
  /// Config de secciones por modalidad de adquisición para EQUIPMENT.
  /// Estructura: { FIXED_ASSET?: { visible: FormSection[], required: FormSection[] }, RENTAL?: {...}, LOAN?: {...} }
  /// Si es null, se usan visibleSections/requiredSections como fallback global.
  sectionsByMode            Json?               @map("sections_by_mode")
  defaultDepreciationMethod DepreciationMethod? @map("default_depreciation_method")
  defaultUsefulLifeYears    Float?              @map("default_useful_life_years")
  defaultResidualValuePct   Float?              @map("default_residual_value_pct")
  codePrefix                String?             @map("code_prefix") @db.VarChar(10)
  autoApproveDecommission   Boolean             @default(false) @map("auto_approve_decommission")
  requireDeliveryAct        Boolean             @default(true) @map("require_delivery_act")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")
  family                    families            @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("inventory_family_config")
}

model ticket_family_config {
  id                         String   @id @default(uuid())
  familyId                   String   @unique @map("family_id")
  ticketsEnabled             Boolean  @default(true) @map("tickets_enabled")
  codePrefix                 String?  @map("code_prefix") @db.VarChar(10)
  isDefault                  Boolean  @default(false) @map("is_default")
  autoAssignRespectsFamilies Boolean  @default(true) @map("auto_assign_respects_families")
  alertVolumeThreshold       Int?     @map("alert_volume_threshold")
  businessHoursStart         String   @default("09:00:00") @map("business_hours_start") @db.VarChar(8)
  businessHoursEnd           String   @default("18:00:00") @map("business_hours_end") @db.VarChar(8)
  businessDays               String   @default("MON,TUE,WED,THU,FRI") @map("business_days") @db.VarChar(50)
  /// IDs de familias cuyos clientes pueden crear tickets aquí.
  /// Array vacío = acepta tickets de clientes de CUALQUIER familia.
  allowedFromFamilies        String[] @default([]) @map("allowed_from_families")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  family                     families @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([ticketsEnabled])
  @@map("ticket_family_config")
}

model technician_family_assignments {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  familyId     String   @map("family_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  family       families @relation(fields: [familyId], references: [id], onDelete: Cascade)
  technician   users    @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, familyId])
  @@index([technicianId, isActive])
  @@index([familyId, isActive])
  @@map("technician_family_assignments")
}

model admin_family_assignments {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  familyId  String   @map("family_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  admin     users    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  family    families @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([adminId, familyId])
  @@index([adminId, isActive])
  @@index([familyId, isActive])
  @@map("admin_family_assignments")
}

model ticket_collaborators {
  id             String   @id @default(uuid())
  ticketId       String   @map("ticket_id")
  collaboratorId String   @map("collaborator_id")
  addedById      String   @map("added_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  addedBy        users    @relation("CollaboratorAddedBy", fields: [addedById], references: [id])
  collaborator   users    @relation("TicketCollaborator", fields: [collaboratorId], references: [id], onDelete: Cascade)
  ticket         tickets  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, collaboratorId])
  @@index([ticketId])
  @@index([collaboratorId])
  @@map("ticket_collaborators")
}

model ticket_code_counters {
  id           String   @id @default(uuid())
  familyId     String   @map("family_id")
  year         Int
  lastSequence Int      @default(0) @map("last_sequence")
  updatedAt    DateTime @updatedAt @map("updated_at")
  family       families @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, year])
  @@index([familyId, year])
  @@map("ticket_code_counters")
}

