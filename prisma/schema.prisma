// ============================================
// INVENTORY MANAGEMENT SYSTEM
// Equipment Types (dynamic catalog)
model equipment_types {
  id          String      @id @default(uuid())
  code        String      @unique // LAPTOP, DESKTOP, etc.
  name        String      // Laptop, Desktop, etc.
  description String?
  icon        String?     // Nombre del ícono de lucide-react
  isActive    Boolean     @default(true) @map("is_active")
  order       Int         @default(0) // Para ordenar en el dropdown
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  equipment   equipment[]
  
  @@index([isActive, order])
  @@map("equipment_types")
}

// ============================================

// Equipment table
model equipment {
  id                   String            @id @default(uuid())
  code                 String            @unique
  serialNumber         String            @map("serial_number")
  brand                String
  model                String
  typeId               String            @map("type_id") // Cambiado de enum a relación
  status               EquipmentStatus   @default(AVAILABLE)
  condition            EquipmentCondition @default(GOOD)
  ownershipType        OwnershipType     @default(FIXED_ASSET) @map("ownership_type")
  purchaseDate         DateTime?         @map("purchase_date")
  purchasePrice        Float?            @map("purchase_price")
  warrantyExpiration   DateTime?         @map("warranty_expiration")
  specifications       Json?
  accessories          String[]
  location             String?
  notes                String?           @db.Text
  photoUrl             String?           @map("photo_url")
  qrCode               String            @unique @map("qr_code")
  
  // Campos para equipos rentados/alquilados
  rentalProvider       String?           @map("rental_provider")
  rentalContractNumber String?           @map("rental_contract_number")
  rentalStartDate      DateTime?         @map("rental_start_date")
  rentalEndDate        DateTime?         @map("rental_end_date")
  rentalMonthlyCost    Float?            @map("rental_monthly_cost")
  rentalContactName    String?           @map("rental_contact_name")
  rentalContactEmail   String?           @map("rental_contact_email")
  rentalContactPhone   String?           @map("rental_contact_phone")
  rentalNotes          String?           @db.Text @map("rental_notes")
  
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  
  type                 equipment_types   @relation(fields: [typeId], references: [id])
  assignments          equipment_assignments[]
  maintenanceRecords   maintenance_records[]
  licenses             software_licenses[]
  consumables          consumables[]
  stockMovements       stock_movements[] @relation("StockMovementEquipment")
  
  @@index([code])
  @@index([serialNumber])
  @@index([typeId, status])
  @@index([status])
  @@index([rentalProvider])
  @@index([rentalEndDate])
  @@map("equipment")
}

enum EquipmentStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  DAMAGED
  RETIRED
}

enum EquipmentCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum OwnershipType {
  FIXED_ASSET
  RENTAL
  LOAN
}

// Equipment assignments table
model equipment_assignments {
  id              String          @id @default(uuid())
  equipmentId     String          @map("equipment_id")
  receiverId      String          @map("receiver_id")
  delivererId     String          @map("deliverer_id")
  assignmentType  AssignmentType  @map("assignment_type")
  startDate       DateTime        @map("start_date")
  endDate         DateTime?       @map("end_date")
  actualEndDate   DateTime?       @map("actual_end_date")
  accessories     String[]
  observations    String?         @db.Text
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  equipment       equipment       @relation(fields: [equipmentId], references: [id])
  receiver        users           @relation("AssignmentReceiver", fields: [receiverId], references: [id])
  deliverer       users           @relation("AssignmentDeliverer", fields: [delivererId], references: [id])
  deliveryAct     delivery_acts?
  returnAct       return_acts?
  
  @@index([equipmentId, isActive])
  @@index([receiverId, isActive])
  @@index([delivererId])
  @@map("equipment_assignments")
}

enum AssignmentType {
  PERMANENT
  TEMPORARY
  LOAN
}

// Delivery acts table
model delivery_acts {
  id                  String          @id @default(uuid())
  folio               String          @unique
  assignmentId        String          @unique @map("assignment_id")
  equipmentSnapshot   Json            @map("equipment_snapshot")
  delivererInfo       Json            @map("deliverer_info")
  receiverInfo        Json            @map("receiver_info")
  accessories         String[]
  observations        String?         @db.Text
  termsVersion        String          @default("1.0") @map("terms_version")
  status              ActStatus       @default(PENDING)
  acceptanceToken     String          @unique @map("acceptance_token")
  expirationDate      DateTime        @map("expiration_date")
  acceptedAt          DateTime?       @map("accepted_at")
  rejectedAt          DateTime?       @map("rejected_at")
  rejectionReason     String?         @db.Text @map("rejection_reason")
  signatureTimestamp  DateTime?       @map("signature_timestamp")
  signatureIp         String?         @map("signature_ip")
  signatureUserAgent  String?         @map("signature_user_agent")
  verificationHash    String?         @map("verification_hash")
  pdfPath             String?         @map("pdf_path")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  
  assignment          equipment_assignments @relation(fields: [assignmentId], references: [id])
  
  @@index([folio])
  @@index([status, expirationDate])
  @@index([acceptanceToken])
  @@map("delivery_acts")
}

enum ActStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// Return acts table
model return_acts {
  id                  String          @id @default(uuid())
  folio               String          @unique
  assignmentId        String          @unique @map("assignment_id")
  deliveryActId       String          @map("delivery_act_id")
  equipmentCondition  EquipmentCondition @map("equipment_condition")
  inspectionNotes     String?         @db.Text @map("inspection_notes")
  returnDate          DateTime        @map("return_date")
  receiverInfo        Json            @map("receiver_info")
  delivererInfo       Json            @map("deliverer_info")
  status              ActStatus       @default(PENDING)
  acceptanceToken     String          @unique @map("acceptance_token")
  expirationDate      DateTime        @map("expiration_date")
  acceptedAt          DateTime?       @map("accepted_at")
  rejectedAt          DateTime?       @map("rejected_at")
  rejectionReason     String?         @db.Text @map("rejection_reason")
  signatureTimestamp  DateTime?       @map("signature_timestamp")
  signatureIp         String?         @map("signature_ip")
  signatureUserAgent  String?         @map("signature_user_agent")
  verificationHash    String?         @map("verification_hash")
  pdfPath             String?         @map("pdf_path")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  
  assignment          equipment_assignments @relation(fields: [assignmentId], references: [id])
  
  @@index([folio])
  @@index([status, expirationDate])
  @@index([acceptanceToken])
  @@map("return_acts")
}

// Maintenance records table
model maintenance_records {
  id              String          @id @default(uuid())
  equipmentId     String          @map("equipment_id")
  type            MaintenanceType
  date            DateTime
  description     String          @db.Text
  technicianId    String          @map("technician_id")
  cost            Float?
  partsReplaced   String[]        @map("parts_replaced")
  ticketId        String?         @map("ticket_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  equipment       equipment       @relation(fields: [equipmentId], references: [id])
  technician      users           @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  ticket          tickets?        @relation(fields: [ticketId], references: [id])
  
  @@index([equipmentId, date])
  @@index([technicianId])
  @@index([ticketId])
  @@map("maintenance_records")
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
}

// License Types (dynamic catalog, like equipment_types)
model license_types {
  id          String              @id @default(uuid())
  code        String              @unique
  name        String
  description String?
  icon        String?
  isActive    Boolean             @default(true) @map("is_active")
  order       Int                 @default(0)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  licenses    software_licenses[]

  @@index([isActive, order])
  @@map("license_types")
}

// Software licenses / contracts table
model software_licenses {
  id                    String          @id @default(uuid())
  name                  String
  typeId                String          @map("type_id")
  key                   String?         @db.Text // Encrypted, optional
  purchaseDate          DateTime?       @map("purchase_date")
  expirationDate        DateTime?       @map("expiration_date")
  cost                  Float?
  vendor                String?
  notes                 String?         @db.Text
  assignedToEquipment   String?         @map("assigned_to_equipment")
  assignedToUser        String?         @map("assigned_to_user")
  assignedToDepartment  String?         @map("assigned_to_department")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  licenseType   license_types?  @relation(fields: [typeId], references: [id])
  equipment     equipment?      @relation(fields: [assignedToEquipment], references: [id], onDelete: SetNull, onUpdate: Cascade)
  user          users?          @relation("LicenseUser", fields: [assignedToUser], references: [id], onDelete: SetNull, onUpdate: Cascade)
  department    departments?    @relation(fields: [assignedToDepartment], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([typeId, expirationDate])
  @@index([assignedToEquipment])
  @@index([assignedToUser])
  @@index([assignedToDepartment])
  @@map("software_licenses")
}

// Consumable Types (dynamic catalog, like equipment_types)
model consumable_types {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  description String?
  icon        String?
  isActive    Boolean       @default(true) @map("is_active")
  order       Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  consumables consumables[]

  @@index([isActive, order])
  @@map("consumable_types")
}

// Units of Measure (dynamic catalog)
model units_of_measure {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  symbol      String
  description String?
  isActive    Boolean       @default(true) @map("is_active")
  order       Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  consumables consumables[]

  @@index([isActive, order])
  @@map("units_of_measure")
}

// Consumables table
model consumables {
  id                  String            @id @default(uuid())
  name                String
  typeId              String            @map("type_id")
  unitOfMeasureId     String            @map("unit_of_measure_id")
  assignedEquipmentId String?           @map("assigned_equipment_id")
  currentStock        Float             @map("current_stock")
  minStock            Float             @map("min_stock")
  maxStock            Float             @map("max_stock")
  costPerUnit         Float?            @map("cost_per_unit")
  location            String?
  notes               String?           @db.Text
  compatibleEquipment String[]          @map("compatible_equipment")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  
  consumableType      consumable_types  @relation(fields: [typeId], references: [id])
  unitOfMeasure       units_of_measure  @relation(fields: [unitOfMeasureId], references: [id])
  assignedEquipment   equipment?        @relation(fields: [assignedEquipmentId], references: [id])
  movements           stock_movements[]
  
  @@index([typeId, currentStock])
  @@index([unitOfMeasureId])
  @@index([assignedEquipmentId])
  @@map("consumables")
}

// Stock movements table
model stock_movements {
  id                  String        @id @default(uuid())
  consumableId        String        @map("consumable_id")
  type                MovementType
  quantity            Float
  reason              String?       @db.Text
  userId              String        @map("user_id")
  assignedToUserId    String?       @map("assigned_to_user_id")
  assignedToEquipmentId String?     @map("assigned_to_equipment_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  
  consumable          consumables   @relation(fields: [consumableId], references: [id])
  user                users         @relation("StockMovementUser", fields: [userId], references: [id])
  assignedToUser      users?        @relation("StockMovementAssignedTo", fields: [assignedToUserId], references: [id])
  assignedToEquipment equipment?    @relation("StockMovementEquipment", fields: [assignedToEquipmentId], references: [id])
  
  @@index([consumableId, createdAt])
  @@index([userId])
  @@index([assignedToUserId])
  @@index([assignedToEquipmentId])
  @@map("stock_movements")
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

// Folio counters table (for sequential folio generation)
model folio_counters {
  id        String   @id @default(uuid())
  year      Int
  type      String   // 'ACT' or 'DEV'
  lastNumber Int     @default(0) @map("last_number")
  
  @@unique([year, type])
  @@map("folio_counters")
}
