# =============================================
# VARIABLES DE ENTORNO — COPIA A .env.local
# =============================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://tickets_user:tickets_password_2024@localhost:5432/tickets_db"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth — genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secret-seguro"
NEXTAUTH_URL="http://localhost:3000"

# Clave de cifrado (misma longitud que NEXTAUTH_SECRET)
ENCRYPTION_KEY="cambia-esto-por-una-clave-de-32-chars"

# Email SMTP (opcional)
EMAIL_FROM_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OAuth Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Microsoft (opcional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# CORS (producción)
CORS_ORIGINS=http://localhost:3000
