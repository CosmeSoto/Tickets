FROM node:20-alpine

WORKDIR /app

# Dependencias del sistema requeridas por Prisma y bcrypt en Alpine
RUN apk add --no-cache libc6-compat curl openssl openssl-dev

# Instalar dependencias de Node ANTES de montar el volumen fuente
# Así el volumen no sobreescribe node_modules del contenedor
COPY package.json package-lock.json ./
RUN npm ci --prefer-offline

# Generar cliente Prisma para la arquitectura Linux del contenedor
COPY prisma ./prisma/
RUN npx prisma generate

EXPOSE 3000

# Entrypoint de desarrollo:
#   1. db push  — sincroniza el schema sin historial de migraciones (dev only)
#   2. db:seed  — datos iniciales idempotentes (upsert)
#   3. next dev — servidor con hot-reload + Turbopack
CMD ["sh", "-c", \
  "npx prisma db push --accept-data-loss && \
   npm run db:seed && \
   npm run dev"]
