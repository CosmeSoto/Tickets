FROM node:20-alpine

WORKDIR /app

# OpenSSL requerido por Prisma en Alpine
RUN apk add --no-cache libc6-compat curl openssl openssl-dev

# Instalar dependencias ANTES de montar el volumen
COPY package.json package-lock.json ./
RUN npm ci

# Generar cliente Prisma para Linux
COPY prisma ./prisma/
RUN npx prisma generate

EXPOSE 3000

# 1. Migrar BD  2. Seed (upsert — idempotente, no duplica)  3. Next dev
CMD ["sh", "-c", "npx prisma migrate deploy && npm run db:seed && npm run dev"]
