FROM node:20-alpine

WORKDIR /app

# OpenSSL requerido por Prisma en Alpine
RUN apk add --no-cache libc6-compat curl openssl openssl-dev

# Instalar dependencias ANTES de montar el volumen
COPY package.json package-lock.json ./
RUN npm ci

# Generar cliente Prisma para Linux
COPY prisma ./prisma/
RUN npx prisma generate

EXPOSE 3000

# 1. Sincronizar BD desde schema (dev: db push, no requiere migraciones)
# 2. Seed (upsert — idempotente, no duplica)
# 3. Next dev
CMD ["sh", "-c", "npx prisma db push --accept-data-loss && npm run db:seed && npm run dev"]
